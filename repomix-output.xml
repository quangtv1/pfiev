from PyInstaller.utils.hooks import collect_data_files

block_cipher = None

a = Analysis(
    ['main.py'],
    pathex=[],
    binaries=[],
    datas=[
        ('resources', 'resources'),
        ('data', 'data'),
    ] + collect_data_files('matplotlib'),
    hiddenimports=[
        'PySide6.QtCore',
        'PySide6.QtWidgets',
        'PySide6.QtGui',
        'PySide6.QtPrintSupport',
        'matplotlib.backends.backend_qtagg',
        'openpyxl',
        'openpyxl.styles',
        'openpyxl.utils',
        'pyodbc',
    ],
    hookspath=[],
    hooksconfig={},
    runtime_hooks=[],
    excludes=[
        'tkinter', 'PyQt5', 'PyQt6',
        'PySide6.QtWebEngine',
        'PySide6.QtWebEngineCore',
        'PySide6.QtWebEngineWidgets',
        'PySide6.QtQuick',
        'PySide6.QtQuick3D',
        'PySide6.QtQuickWidgets',
        'PySide6.QtQml',
        'PySide6.QtCharts',
        'PySide6.QtMultimedia',
        'PySide6.QtMultimediaWidgets',
        'PySide6.QtTest',
        'PySide6.QtBluetooth',
        'PySide6.QtNfc',
        'PySide6.QtWebSockets',
        'PySide6.QtLocation',
        'PySide6.QtPositioning',
        'PySide6.QtSensors',
        'PySide6.QtSerialPort',
        'PySide6.Qt3DCore',
        'PySide6.Qt3DRender',
        'PySide6.Qt3DInput',
        'PySide6.Qt3DLogic',
        'PySide6.Qt3DAnimation',
        'PySide6.Qt3DExtras',
        'PySide6.QtDataVisualization',
        'PySide6.QtVirtualKeyboard',
        'PySide6.QtRemoteObjects',
        'PySide6.QtSpatialAudio',
    ],
    win_no_prefer_redirects=False,
    win_private_assemblies=False,
    cipher=block_cipher,
)

pyz = PYZ(a.pure, a.zipped_data, cipher=block_cipher)

exe = EXE(
    pyz,
    a.scripts,
    [],
    exclude_binaries=True,
    name='OrientationPFIEV',
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=False,  # UPX disabled to avoid antivirus false positive
    console=False,  # --windowed
    disable_windowed_traceback=False,
    target_arch=None,
    codesign_identity=None,
    entitlements_file=None,
    icon='resources/iconPFEIV.ico',
)

coll = COLLECT(
    exe,
    a.binaries,
    a.zipfiles,
    a.datas,
    strip=False,
    upx=False,
    upx_exclude=[],
    name='OrientationPFIEV',
)
</file>

<file path="OrientationPFIEV/OrientationPFIEV.csproj">
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!-- Target Windows: net9.0-windows for WinForms support on the build machine -->
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <!-- UseWindowsForms requires Microsoft.NET.Sdk.WindowsDesktop (Windows-only SDK).
         Set to true for Windows builds; on macOS CI this is omitted to allow restore. -->
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- x86 required for OleDb 32-bit Access ODBC driver -->
    <PlatformTarget>x86</PlatformTarget>
    <ApplicationIcon>Resources\iconPFEIV.ico</ApplicationIcon>
    <AssemblyName>OrientationPFIEV</AssemblyName>
    <RootNamespace>OrientationPFIEV</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.102.*" />
    <PackageReference Include="System.Data.OleDb" Version="8.*" />
    <PackageReference Include="OxyPlot.WindowsForms" Version="2.*" />
  </ItemGroup>


  <ItemGroup>
    <Content Include="Resources\logo.jpg"       CopyToOutputDirectory="PreserveNewest" Condition="Exists('Resources\logo.jpg')" />
    <Content Include="Resources\iconPFEIV.ico"  CopyToOutputDirectory="PreserveNewest" Condition="Exists('Resources\iconPFEIV.ico')" />
    <Content Include="Resources\french.gif"     CopyToOutputDirectory="PreserveNewest" Condition="Exists('Resources\french.gif')" />
    <Content Include="Resources\vietnam.gif"    CopyToOutputDirectory="PreserveNewest" Condition="Exists('Resources\vietnam.gif')" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Database\CONFIG.MDB">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Database\InitBase.mdb">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
</file>

<file path=".github/workflows/build.yml">
name: Build OrientationPFIEV Python

on:
  push:
    branches: [ main ]
    tags: [ 'v*' ]
  workflow_dispatch:

jobs:
  build:
    runs-on: windows-latest
    permissions:
      contents: write

    steps:
      - uses: actions/checkout@v4

      - name: Setup Python 3.12
        uses: actions/setup-python@v5
        with:
          python-version: '3.12'

      - name: Install dependencies
        run: |
          pip install --upgrade pip
          pip install -r requirements.txt
          pip install pyinstaller pyinstaller-hooks-contrib pyodbc

      - name: Create SQLite databases
        run: python scripts/create_dbs.py

      - name: Build exe with PyInstaller
        run: pyinstaller OrientationPFIEV.spec

      - name: Package into ZIP
        run: Compress-Archive -Path dist/OrientationPFIEV -DestinationPath OrientationPFIEV-Python-win-x64.zip

      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: OrientationPFIEV-Python-win-x64
          path: OrientationPFIEV-Python-win-x64.zip
          retention-days: 30

      - name: Create GitHub Release
        if: startsWith(github.ref, 'refs/tags/')
        uses: softprops/action-gh-release@v2
        with:
          files: OrientationPFIEV-Python-win-x64.zip
          name: OrientationPFIEV Python ${{ github.ref_name }}
          body: |
            ## OrientationPFIEV Python ${{ github.ref_name }}

            Ứng dụng PFIEV viết bằng Python 3.12 + PySide6.

            ### Cài đặt
            1. Tải `OrientationPFIEV-Python-win-x64.zip`
            2. Giải nén toàn bộ thư mục
            3. Chạy `OrientationPFIEV.exe` — không cần cài Python
</file>

</files>
